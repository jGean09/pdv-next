generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  price       Float
  cost        Float
  quantity    Int
  active      Boolean     @default(true) // <-- ADICIONE ESTA LINHA
  categoryId  Int
  category    Category    @relation(fields: [categoryId], references: [id])
  sales       SaleItem[]
  createdAt   DateTime    @default(now())
}

model Client {
  id      Int     @id @default(autoincrement())
  name    String
  phone   String?
  address String?
  sales   Sale[]  // ADICIONADO: O Prisma exige isso para a relação com Sale
}

model Sale {
  id         Int        @id @default(autoincrement())
  customerId Int?
  total      Float
  createdAt  DateTime   @default(now())
  client     Client?    @relation(fields: [customerId], references: [id])
  items      SaleItem[]
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  price     Float
  quantity  Int
  sale      Sale    @relation(fields: [saleId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}